/**
  ******************************************************************************
  * @file           : main.c
  * @brief          : Minimal LED blink — generated by the ViewAlyzer `scaffold` tool.
  *
  * Portable: it toggles the board's onboard LED with raw HAL_GPIO (no vendor BSP)
  * and uses the default SysTick timebase (HAL_Init installs it). The LED pin comes
  * from the board file; SystemClock_Config is the family default (MSI).
  ******************************************************************************
  */
#include "main.h"

/* Onboard LED (from the board file). */
#define LED_GPIO_PORT   GPIO{led_port}
#define LED_PIN         GPIO_PIN_{led_pin}

void SystemClock_Config(void);
static void LED_Init(void);

/**
  * @brief  Application entry point.
  */
int main(void)
{
  /* Reset of all peripherals, init the Flash interface and the SysTick. */
  HAL_Init();

  /* Configure the system clock (family default: MSI). */
  SystemClock_Config();

  /* Initialize the onboard LED. */
  LED_Init();

  /* Infinite loop: ~1 Hz heartbeat. HAL_Delay is milliseconds regardless of HCLK. */
  while (1)
  {
    HAL_GPIO_TogglePin(LED_GPIO_PORT, LED_PIN);
    HAL_Delay(500);
  }
}

/**
  * @brief  Configure the onboard LED pin as a push-pull output.
  */
static void LED_Init(void)
{
  GPIO_InitTypeDef gpio = {0};

  {led_clk_enable}();

  gpio.Pin   = LED_PIN;
  gpio.Mode  = GPIO_MODE_OUTPUT_PP;
  gpio.Pull  = GPIO_NOPULL;
  gpio.Speed = GPIO_SPEED_FREQ_LOW;
  HAL_GPIO_Init(LED_GPIO_PORT, &gpio);

  HAL_GPIO_WritePin(LED_GPIO_PORT, LED_PIN, GPIO_PIN_RESET);
}

