cmake_minimum_required(VERSION 3.22)

# Generated by the ViewAlyzer harness `scaffold` tool. Single flat CMakeLists (glob the
# vendored HAL Src); `--gc-sections` in the toolchain file strips whatever the blinky
# doesn't call, so vendoring the full HAL needs no per-peripheral dependency analysis.

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)
set(CMAKE_C_EXTENSIONS ON)

# Set before project() so the toolchain file's -Wl,-Map=${CMAKE_PROJECT_NAME}.map resolves.
set(CMAKE_PROJECT_NAME {name})

project(${CMAKE_PROJECT_NAME} C ASM)
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

# Vendored HAL sources (full driver set; unused modules #ifdef out via hal_conf.h and are
# stripped by --gc-sections). ST ships `*_template.c` example files in Src (an MSP stub, the
# alternate timebases) that each redefine HAL_MspInit/HAL_InitTick — never compiled by a real
# project. Drop them, or they collide at link.
file(GLOB HAL_SRC CONFIGURE_DEPENDS ${CMAKE_SOURCE_DIR}/Drivers/{family}xx_HAL_Driver/Src/*.c)
list(FILTER HAL_SRC EXCLUDE REGEX "_template\\.c$")

add_executable(${CMAKE_PROJECT_NAME}
    Core/Src/main.c
    Core/Src/{family_l}xx_it.c
    Core/Src/{family_l}xx_hal_msp.c
    Core/Src/system_{family_l}xx.c
    Core/Src/syscalls.c
    Core/Src/sysmem.c
    startup_{cmsis_device}.s
    ${HAL_SRC}
)

target_include_directories(${CMAKE_PROJECT_NAME} PRIVATE
    Core/Inc
    Drivers/{family}xx_HAL_Driver/Inc
    Drivers/{family}xx_HAL_Driver/Inc/Legacy
    Drivers/CMSIS/Device/ST/{family}xx/Include
    Drivers/CMSIS/Include
)

target_compile_definitions(${CMAKE_PROJECT_NAME} PRIVATE
    USE_HAL_DRIVER
    {cpp_define}
    $<$<CONFIG:Debug>:DEBUG>
)

target_link_libraries(${CMAKE_PROJECT_NAME} m)

# Emit a raw binary + hex + size alongside the ELF (handy for flashing/inspection).
add_custom_command(TARGET ${CMAKE_PROJECT_NAME} POST_BUILD
    COMMAND ${CMAKE_SIZE} $<TARGET_FILE:${CMAKE_PROJECT_NAME}>
    COMMAND ${CMAKE_OBJCOPY} -O ihex   $<TARGET_FILE:${CMAKE_PROJECT_NAME}> ${CMAKE_PROJECT_NAME}.hex
    COMMAND ${CMAKE_OBJCOPY} -O binary $<TARGET_FILE:${CMAKE_PROJECT_NAME}> ${CMAKE_PROJECT_NAME}.bin
)
